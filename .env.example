# LLM API Keys (shared pool)
GEMINI_API_KEY=AIza_YOUR_KEY_HERE
GROQ_API_KEY=gsk_YOUR_KEY_HERE
OPENROUTER_API_KEY=sk-or-YOUR_KEY_HERE

# BYOK Encryption (generate dengan: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
BYOK_ENCRYPTION_KEY=YOUR_FERNET_KEY_HERE

# BYOK database path (default: backend/byok_store.json)
BYOK_DB_PATH=/data/byok_store.json

# Redis (untuk rate limit tracking, opsional — fallback ke in-memory)
REDIS_URL=redis://localhost:6379

# App
DEBUG=true
