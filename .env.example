# 9router API Key (wajib)
# Install: npm install -g 9router && 9router
# Dashboard: http://localhost:20128/dashboard
9ROUTER_API_KEY=your-9router-api-key

# 9router base URL (default: http://localhost:20128/v1)
# 9ROUTER_BASE_URL=http://localhost:20128/v1

# Model yang digunakan (default: groq/llama-3.3-70b-versatile untuk teks, gemini/gemini-3.1-flash-lite-preview untuk vision)
# 9ROUTER_MODEL=groq/llama-3.3-70b-versatile
# 9ROUTER_VISION_MODEL=gemini/gemini-3.1-flash-lite-preview

# BYOK Encryption
BYOK_ENCRYPTION_KEY=YOUR_FERNET_KEY_HERE

# BYOK database path (default: backend/byok_store.json)
# BYOK_DB_PATH=/data/byok_store.json

# Redis (untuk rate limit tracking, opsional — fallback ke in-memory)
# REDIS_URL=redis://localhost:6379

# App
DEBUG=true
